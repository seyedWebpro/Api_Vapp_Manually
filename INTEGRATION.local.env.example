# ═══════════════════════════════════════════════════════════════
# Vapp ↔ Number Scraper — مرجع تنظیمات اتصال (Development)
# کپی: cp INTEGRATION.local.env.example INTEGRATION.local.env
# ═══════════════════════════════════════════════════════════════

# کلید مشترک — باید در هر دو سمت یکسان باشد
INTEGRATION_API_KEY=dev-local-key

# آدرس‌ها
VAPP_API_URL=http://localhost:5054
SCRAPER_API_URL=http://localhost:8000

# Python (.env در scraping_Number_Vapp)
# API_KEY=dev-local-key
# API_KEY_REQUIRED=true
# DOTNET_WEBHOOK_ENABLED=true
# DOTNET_WEBHOOK_URL=http://localhost:5054/api/NumberSeeker/internal/webhook/task-completed
# DOTNET_WEBHOOK_API_KEY=dev-local-key

# .NET (appsettings.Development.Mac.json)
# NumberScraperApi:BaseUrl = http://localhost:8000
# NumberScraperApi:ApiKey   = dev-local-key

# SQL Docker
# Vapp SQL:    localhost:1436  sa / Vapp@Secure2025!
# Scraper SQL: localhost:1437  sa / PhoneScraper@Secure2025!
