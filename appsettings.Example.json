{
  "localConnection": "Data Source=.;Initial Catalog=DbVappLocal;Integrated Security=True;Trust Server Certificate=True",
  "defultConnection": "Data Source=YOUR_SERVER;Initial Catalog=YOUR_DATABASE;User ID=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;Encrypt=False;",

  "Jwt": {
    "Secret": "CHANGE_ME_AtLeast32CharactersLongSecretKey",
    "Issuer": "VappShop",
    "Audience": "VappSiteUsers",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 1
  },

  "Development": {
    "DisableAuth": true,
    "DisableWalletCheck": true
  },
  "Production": {
    "DisableAuth": false,
    "DisableWalletCheck": true
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Kestrel": {
    "Limits": {
      "MaxRequestBodySize": 2147483648,
      "RequestHeadersTimeout": "00:05:00",
      "KeepAliveTimeout": "00:05:00"
    }
  },

  "IIS": {
    "MaxRequestBodySize": 2147483648
  },

  "FileUpload": {
    "MaxFileSize": 2147483648,
    "UploadsFolder": "wwwroot/uploads",
    "AllowedFileTypes": [
      "image/jpeg",
      "image/png",
      "image/gif",
      "image/webp",
      "video/mp4",
      "application/pdf"
    ],
    "UseOriginalFileName": false,
    "BaseUrl": ""
  },

  "Payment": {
    "Behpardakht": {
      "TerminalId": "YOUR_TERMINAL_ID",
      "Username": "YOUR_USERNAME",
      "Password": "YOUR_PASSWORD",
      "PaymentUrl": "https://bpm.shaparak.ir/pgwchannel/startpay.mellat",
      "CallbackUrl": "http://localhost:5054/api/payment/callback/behpardakht",
      "FrontendCallbackUrl": "/payment/result"
    },
    "SimulationUrl": "/payment/simulation"
  },

  "ZarinPal": {
    "MerchantId": "YOUR_ZARINPAL_MERCHANT_ID",
    "CallbackUrl": "http://localhost:5054/api/payment/verify",
    "Sandbox": true
  },

  "Cache": {
    "Provider": "Memory",
    "DefaultExpirationMinutes": 30,
    "EnableCache": true,
    "MemoryCache": {
      "SizeLimit": 1024
    }
  },

  "RateLimit": {
    "EnableRateLimit": true,
    "Provider": "Memory",
    "DefaultPolicy": {
      "PermitLimit": 100,
      "WindowSeconds": 60,
      "Strategy": "FixedWindow",
      "KeyType": "IP"
    },
    "WhitelistIps": ["127.0.0.1", "::1"],
    "BlacklistIps": []
  },

  "Sms": {
    "ApiKey": "YOUR_SMS_API_KEY",
    "BaseUrl": "https://irannovinsms.ir",
    "SenderNumber": "YOUR_SENDER_NUMBER"
  },

  "AllowedHosts": "*"
}
