{
  "DatabaseProvider": "Local",
  "ConnectionStrings": {
    "LocalConnection": "Server=.;Database=DbVappLocal;Trusted_Connection=True;TrustServerCertificate=True;Encrypt=False;MultipleActiveResultSets=true;Max Pool Size=100;Min Pool Size=5;Connection Timeout=30;Pooling=true;",
    "LocalDockerHostConnection": "Server=localhost,1436;Database=DbVapp;User Id=sa;Password=CHANGE_ME;TrustServerCertificate=True;Encrypt=False;MultipleActiveResultSets=true;Max Pool Size=100;Min Pool Size=5;Connection Timeout=30;Pooling=true;",
    "DockerConnection": "Server=sqlserver;Database=DbVapp;User Id=sa;Password=CHANGE_ME;TrustServerCertificate=True;Encrypt=False;MultipleActiveResultSets=true;Max Pool Size=100;Min Pool Size=5;Connection Timeout=30;Pooling=true;"
  },
  "localConnection": "Data Source=.;Initial Catalog=DbVappLocal;Integrated Security=True;Trust Server Certificate=True",
  "defultConnection": "Data Source=YOUR_SERVER;Initial Catalog=YOUR_DATABASE;User ID=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;Encrypt=False;",

  "Jwt": {
    "Secret": "CHANGE_ME_AtLeast32CharactersLongSecretKey",
    "Issuer": "VappShop",
    "Audience": "VappSiteUsers",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 1
  },

  "Development": {
    "DisableAuth": true,
    "DisableWalletCheck": true
  },
  "Production": {
    "DisableAuth": false,
    "DisableWalletCheck": true
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.File", "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "log/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}",
          "encoding": "UTF8"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },

  "Kestrel": {
    "Limits": {
      "MaxRequestBodySize": 2147483648,
      "RequestHeadersTimeout": "00:05:00",
      "KeepAliveTimeout": "00:05:00"
    }
  },

  "IIS": {
    "MaxRequestBodySize": 2147483648
  },

  "FileUpload": {
    "MaxFileSize": 2147483648,
    "UploadsFolder": "wwwroot/uploads",
    "AllowedFileTypes": [
      "image/jpeg",
      "image/png",
      "image/gif",
      "image/webp",
      "video/mp4",
      "application/pdf"
    ],
    "UseOriginalFileName": false,
    "BaseUrl": ""
  },

  "FormBuilder": {
    "PublicBaseUrl": "https://app.com/form"
  },

  "LuckyWheel": {
    "PublicBaseUrl": "https://app.com/wheel"
  },

  "BookingSystem": {
    "PublicBaseUrl": "https://app.com/book"
  },

  "Payment": {
    "Behpardakht": {
      "TerminalId": "YOUR_TERMINAL_ID",
      "Username": "YOUR_USERNAME",
      "Password": "YOUR_PASSWORD",
      "PaymentUrl": "https://bpm.shaparak.ir/pgwchannel/startpay.mellat",
      "CallbackUrl": "http://localhost:5054/api/payment/callback/behpardakht",
      "FrontendCallbackUrl": "/payment/result"
    },
    "SimulationUrl": "/payment/simulation"
  },

  "ZarinPal": {
    "MerchantId": "YOUR_ZARINPAL_MERCHANT_ID",
    "CallbackUrl": "http://localhost:5054/api/payment/verify",
    "Sandbox": true
  },

  "Cache": {
    "Provider": "Memory",
    "DefaultExpirationMinutes": 30,
    "EnableCache": true,
    "MemoryCache": {
      "SizeLimit": 1024
    }
  },

  "RateLimit": {
    "EnableRateLimit": true,
    "Provider": "Memory",
    "DefaultPolicy": {
      "PermitLimit": 100,
      "WindowSeconds": 60,
      "Strategy": "FixedWindow",
      "KeyType": "IP"
    },
    "WhitelistIps": ["127.0.0.1", "::1"],
    "BlacklistIps": []
  },

  "Sms": {
    "ApiKey": "YOUR_SMS_API_KEY",
    "BaseUrl": "https://irannovinsms.ir",
    "SenderNumber": "YOUR_SENDER_NUMBER",
    "DeliverySync": {
      "CheckIntervalMinutes": 15,
      "MinAgeBeforeFirstCheckMinutes": 60,
      "MaxCheckAttempts": 48,
      "MaxSidsPerBatch": 50
    }
  },

  "AllowedHosts": "*"
}
