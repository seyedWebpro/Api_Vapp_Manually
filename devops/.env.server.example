# env نمونه production — کپی به docker/.env
# reuse: رمز DB، JWT، URL عمومی، env vars مخصوص stack (Node، Python، …)
#
#   cp ~/Api_Vapp_Manually/devops/.env.server.example ~/Api_Vapp_Manually/docker/.env

SA_PASSWORD=CHANGE_ME_StrongPassword!

# پشت Nginx — API فقط localhost
API_PORT_MAPPING=127.0.0.1:8080:8080

# آدرس عمومی (برای callback پرداخت / SMS / لینک فرم و گردونه)
# production دامنه: https://ok-sms.ir — راهنما: devops/domain/README.md
PUBLIC_API_BASE_URL=https://ok-sms.ir
PUBLIC_FRONTEND_URL=https://ok-sms.ir
FORM_PUBLIC_BASE_URL=https://ok-sms.ir/form
WHEEL_PUBLIC_BASE_URL=https://ok-sms.ir/wheel
BOOKING_PUBLIC_BASE_URL=https://ok-sms.ir/book

# JWT (حداقل ۳۲ کاراکتر)
Jwt__Secret=CHANGE_ME_AtLeast32CharactersLongSecretKey

# ═══ Number Scraper (شماره‌جو) — ربات روی همان سرور ═══
# راهنمای کامل: devops/NUMBER-SCRAPER.md
#
# API Key باید با API_KEY در ~/scraping_Number_Vapp/.env یکسان باشد
SCRAPER_API_KEY=CHANGE_ME_ScraperApiKey_Min16Chars
NumberScraperApi__Enabled=true
NumberScraperApi__BaseUrl=http://host.docker.internal:8000
NumberScraperApi__ApiKey=${SCRAPER_API_KEY}
NumberScraperApi__TimeoutSeconds=120
#
# نکته ربات: API_PORT_MAPPING=8000:8000 (نه 127.0.0.1) — وگرنه Vapp به ربات وصل نمی‌شود

# SMS (اختیاری)
# Sms__ApiKey=
# Sms__SenderNumber=
