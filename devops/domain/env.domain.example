# نمونه docker/.env — حالت دامنه ok-sms.ir
# کپی: cp devops/domain/env.domain.example docker/.env && nano .env
# یا: bash devops/scripts/switch-to-domain.sh
#
# بعد از ویرایش — فقط API را recreate کنید (SQL دست نخورَد):
#   cd ~/Api_Vapp_Manually && docker compose -f docker/docker-compose.production.yml --env-file docker/.env up -d --no-deps --force-recreate api

SA_PASSWORD=CHANGE_ME_StrongPassword!
API_PORT_MAPPING=127.0.0.1:8080:8080

# آدرس عمومی — بدون اسلش انتهایی (بعد از Certbot: https)
PUBLIC_API_BASE_URL=https://ok-sms.ir
PUBLIC_FRONTEND_URL=https://ok-sms.ir
FORM_PUBLIC_BASE_URL=https://ok-sms.ir/form
WHEEL_PUBLIC_BASE_URL=https://ok-sms.ir/wheel
BOOKING_PUBLIC_BASE_URL=https://ok-sms.ir/book

Jwt__Secret=CHANGE_ME_AtLeast32CharactersLongSecretKey

# SMS (اختیاری)
# Sms__ApiKey=
# Sms__SenderNumber=
