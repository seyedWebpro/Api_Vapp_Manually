@Api_Vapp_HostAddress = http://localhost:5054

GET {{Api_Vapp_HostAddress}}/weatherforecast/
Accept: application/json

###

# --- LuckyWheel (گردونه شانس) — نیاز به JWT یا Development:DisableAuth=true ---

### ایجاد پیش‌نویس (مرحله ۱)
POST {{Api_Vapp_HostAddress}}/api/LuckyWheel
Content-Type: application/json

{
  "title": "گردونه نوروز",
  "description": "شانس خود را امتحان کنید",
  "saveToPhonebook": false,
  "notebookIds": []
}

### به‌روزرسانی جوایز (مرحله ۲) — wheelId را جایگزین کنید
POST {{Api_Vapp_HostAddress}}/api/LuckyWheel/1/update
Content-Type: application/json

{
  "items": [
    { "name": "۱۰٪ تخفیف", "probability": 30, "displayOrder": 1 },
    { "name": "۲۰٪ تخفیف", "probability": 30, "displayOrder": 2 },
    { "name": "پوچ", "probability": 40, "displayOrder": 3 }
  ]
}

### افزودن یک آیتم جدید (دکمه +)
POST {{Api_Vapp_HostAddress}}/api/LuckyWheel/1/items/add
Content-Type: application/json

{
  "name": "۳۰٪ تخفیف",
  "probability": 20,
  "displayOrder": 4
}

### جزئیات گردونه (Preview)
GET {{Api_Vapp_HostAddress}}/api/LuckyWheel/1

### انتشار و دریافت لینک
POST {{Api_Vapp_HostAddress}}/api/LuckyWheel/1/publish
Content-Type: application/json

{
  "slug": "norooz-wheel"
}

### لیست گردونه‌ها
GET {{Api_Vapp_HostAddress}}/api/LuckyWheel?pageNumber=1&pageSize=10

### ویرایش اطلاعات اصلی (تنظیمات)
POST {{Api_Vapp_HostAddress}}/api/LuckyWheel/1/update
Content-Type: application/json

{
  "title": "گردونه جشن تابستانه",
  "description": "توضیح جدید",
  "slug": "summer-festival",
  "saveToPhonebook": true,
  "notebookIds": [1]
}

### فعال/غیرفعال (تنظیمات)
POST {{Api_Vapp_HostAddress}}/api/LuckyWheel/1/toggle-active
Content-Type: application/json

{
  "isActive": false
}

### حذف گردونه
POST {{Api_Vapp_HostAddress}}/api/LuckyWheel/1/delete

###

# --- UserSubscription (اشتراک) — نیاز به JWT یا Development:DisableAuth=true ---
# ترتیب تست: ۱) catalog  →  planId پلن Plus/Gold را بردار  →  ۲) preview  →  ۳) purchase

### ۱) کاتالوگ — اشتراک فعلی + لیست پلن‌ها
GET {{Api_Vapp_HostAddress}}/api/UserSubscription/catalog
Accept: application/json

### ۲) پیش‌نمایش checkout (بدون کد تخفیف) — planId را از catalog جایگزین کنید
POST {{Api_Vapp_HostAddress}}/api/UserSubscription/checkout/preview
Content-Type: application/json

{
  "planId": 2
}

### ۲-ب) پیش‌نمایش با کد تخفیف (اختیاری)
POST {{Api_Vapp_HostAddress}}/api/UserSubscription/checkout/preview
Content-Type: application/json

{
  "planId": 2,
  "discountCode": "YOUR-CODE"
}

### ۳) شروع خرید — درگاه Behpardakht (شبیه‌سازی شده، redirectUrl برمی‌گردد)
POST {{Api_Vapp_HostAddress}}/api/UserSubscription/purchase
Content-Type: application/json

{
  "planId": 2,
  "gateway": "Behpardakht"
}

###

# --- Contact / Message — انتخاب دستی گیرندگان پیامک ---

### لیست مخاطبین کاربر (برای UI چک‌باکس)
GET {{Api_Vapp_HostAddress}}/api/Contact/mine?pageNumber=1&pageSize=20&searchTerm=

### انتخاب گیرندگان — ContactIds (انتخاب دستی)
POST {{Api_Vapp_HostAddress}}/api/Message/recipients/select
Content-Type: application/json

{
  "messageId": 1,
  "selectionType": "ContactIds",
  "contactIds": [1, 2]
}

###

# --- BookingSystem (رزرو نوبت) ---

### عمومی — اطلاعات صفحه رزرو (بدون Auth)
GET {{Api_Vapp_HostAddress}}/api/BookingPublic/beauty-salon

### عمومی — اسلات‌های خالی
GET {{Api_Vapp_HostAddress}}/api/BookingPublic/beauty-salon/services/1/slots?date=2026-07-15

### عمومی — ثبت نوبت
POST {{Api_Vapp_HostAddress}}/api/BookingPublic/beauty-salon/book
Content-Type: application/json

{
  "serviceId": 1,
  "startUtc": "2026-07-15T05:30:00Z",
  "customerFullName": "علی تست",
  "customerMobile": "09121234567"
}

### ویزارد — مرحله ۱ (نیاز به JWT + online_booking)
POST {{Api_Vapp_HostAddress}}/api/BookingSystem/validate-step1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "سالن زیبایی",
  "activityType": "beauty_salon",
  "saveToPhonebook": false,
  "notebookIds": []
}

###
