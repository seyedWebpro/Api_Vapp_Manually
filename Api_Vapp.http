@Api_Vapp_HostAddress = http://localhost:5054

GET {{Api_Vapp_HostAddress}}/weatherforecast/
Accept: application/json

###

# --- LuckyWheel (گردونه شانس) — نیاز به JWT یا Development:DisableAuth=true ---

### ایجاد پیش‌نویس (مرحله ۱)
POST {{Api_Vapp_HostAddress}}/api/LuckyWheel
Content-Type: application/json

{
  "title": "گردونه نوروز",
  "description": "شانس خود را امتحان کنید",
  "saveToPhonebook": false,
  "notebookIds": []
}

### به‌روزرسانی جوایز (مرحله ۲) — wheelId را جایگزین کنید
POST {{Api_Vapp_HostAddress}}/api/LuckyWheel/1/items/add
Content-Type: application/json

{
  "items": [
    { "name": "۱۰٪ تخفیف", "probability": 30, "displayOrder": 1 },
    { "name": "۲۰٪ تخفیف", "probability": 30, "displayOrder": 2 },
    { "name": "پوچ", "probability": 40, "displayOrder": 3 }
  ]
}

### افزودن یک یا چند آیتم جدید (دکمه +)
POST {{Api_Vapp_HostAddress}}/api/LuckyWheel/1/items/add
Content-Type: application/json

{
  "items": [
    {
      "name": "۳۰٪ تخفیف",
      "probability": 20,
      "displayOrder": 4
    }
  ]
}

### به‌روزرسانی جزئی جوایز (ویرایش درصد/نام/ترتیب)
POST {{Api_Vapp_HostAddress}}/api/LuckyWheel/1/items/update
Content-Type: application/json

{
  "items": [
    {
      "id": 5,
      "name": "درصد جدید",
      "probability": 50,
      "displayOrder": 1
    },
    {
      "name": "جایزه جدید",
      "probability": 10,
      "displayOrder": 5
    }
  ]
}

### جزئیات گردونه (Preview)
GET {{Api_Vapp_HostAddress}}/api/LuckyWheel/1

### انتشار و دریافت لینک
POST {{Api_Vapp_HostAddress}}/api/LuckyWheel/1/publish
Content-Type: application/json

{
  "slug": "norooz-wheel"
}

### لیست گردونه‌ها
GET {{Api_Vapp_HostAddress}}/api/LuckyWheel?pageNumber=1&pageSize=10

### ویرایش اطلاعات اصلی (تنظیمات)
POST {{Api_Vapp_HostAddress}}/api/LuckyWheel/1/update-info
Content-Type: application/json

{
  "title": "گردونه جشن تابستانه",
  "description": "توضیح جدید",
  "slug": "summer-festival",
  "saveToPhonebook": true,
  "notebookIds": [1]
}

### فعال/غیرفعال (تنظیمات)
POST {{Api_Vapp_HostAddress}}/api/LuckyWheel/1/toggle-active
Content-Type: application/json

{
  "isActive": false
}

### حذف گردونه
POST {{Api_Vapp_HostAddress}}/api/LuckyWheel/1/delete

###

# --- FormPublic (فرم عمومی) — بدون Auth ---

### دریافت schema فرم منتشرشده
GET {{Api_Vapp_HostAddress}}/api/FormPublic/contact-form

### ثبت پاسخ فرم
POST {{Api_Vapp_HostAddress}}/api/FormPublic/contact-form/submit
Content-Type: application/json

{
  "participantFullName": "علی رضایی",
  "participantMobile": "09121112233",
  "values": {
    "full_name": "علی رضایی",
    "mobile": "09121112233"
  }
}

